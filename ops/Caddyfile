# Caddy origin for NekoPath (docs/IMPLEMENTATION_MASTER_PLAN.md §8/§13).
# The canonical hostname is served by a Cloudflare Worker custom domain. The
# sslip.io hostname gives that Worker an independently verifiable HTTPS origin.

# Cloudflare owns the public TLS certificate for the canonical hostname. Caddy
# terminates TLS only for the private origin hostname used by that Worker.
nekopath-origin.34-142-197-144.sslip.io {
	encode zstd gzip

	# Never let intermediaries cache the SW-critical trio.
	@swCritical path /index.html /sw.js /manifest.webmanifest /
	header @swCritical Cache-Control "no-cache"

	# Hashed assets are immutable.
	@hashed path /assets/*
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	header {
		# connect-src allows Hugging Face + GitHub raw for the ONE-TIME WebLLM
		# Gemma weight download (cached after; inference is fully offline).
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://huggingface.co https://*.huggingface.co https://*.hf.co https://raw.githubusercontent.com; font-src 'self'; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		X-Frame-Options "DENY"
		X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
		Strict-Transport-Security "max-age=31536000"
	}

	reverse_proxy app:3001
}
