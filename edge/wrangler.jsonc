{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "nekopath-edge",
  "main": "worker.ts",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "nekopath.holilihu.online",
      "custom_domain": true,
    },
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
  },
}
